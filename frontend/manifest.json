{
  "manifest_version": 3,
  "name": "AI Job-Aware Gmail Copilot",
  "version": "0.1.0",
  "description": "Agentic AI copilot for Gmail with multi-agent analysis and draft support.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
